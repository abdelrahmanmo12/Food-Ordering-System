spring.application.name=payment-service

# Server Configuration
server.port=8084

# Database Configuration - MySQL
# Set DB_PASSWORD environment variable or replace ${DB_PASSWORD} with actual password
spring.datasource.url=jdbc:mysql://localhost:3306/payment_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=${DB_PASSWORD:your_password_here}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
stripe.secret.key=${STRIPE_SECRET_KEY:your_stripe_secret_key_here}
stripe.webhook.secret=${STRIPE_WEBHOOK_SECRET:your_stripe_webhook_secret_here}

# Actuator Configuration
# Expose only necessary endpoints for security
management.endpoints.web.exposure.include=health,info
management.health.defaults.enabled=true

# Logging Configuration
logging.level.com.foodordering.payment=INFO
logging.level.org.springframework.security=INFO
